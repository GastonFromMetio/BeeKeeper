                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Saisir uniquement le token brut dans Swagger UI. Le prefixe Bearer est ajoute automatiquement.",
                "bearerFormat": "Bearer token",
                "scheme": "bearer"
            }
        }
