    "components": {
        "schemas": {
            "User": {
                "required": [
                    "id",
                    "name",
                    "email"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Alice Martin"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "alice@example.com"
                    },
                    "email_verified_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": null,
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "Rucher": {
                "required": [
                    "id",
                    "user_id",
                    "name",
                    "localisation",
                    "nb_emplacements"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "user_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Rucher des Tilleuls"
                    },
                    "localisation": {
                        "type": "string",
                        "example": "Lyon"
                    },
                    "description": {
                        "type": "string",
                        "example": "Rucher principal",
                        "nullable": true
                    },
                    "nb_emplacements": {
                        "type": "integer",
                        "example": 12,
                        "minimum": 0
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "Ruche": {
                "required": [
                    "id",
                    "rucher_id",
                    "nom",
                    "statut",
                    "type_ruche"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "rucher_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "nom": {
                        "type": "string",
                        "example": "Ruche 01"
                    },
                    "statut": {
                        "type": "string",
                        "example": "active"
                    },
                    "type_ruche": {
                        "type": "string",
                        "example": "Dadant"
                    },
                    "annee_reine": {
                        "type": "integer",
                        "example": 2024,
                        "nullable": true
                    },
                    "notes": {
                        "type": "string",
                        "example": "Colonie tres dynamique",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "rucher": {
                        "oneOf": [
                            {
                                "$ref": "#/components/schemas/Rucher"
                            }
                        ],
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "RegisterRequest": {
                "required": [
                    "name",
                    "email",
                    "password",
                    "password_confirmation"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Alice Martin"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "alice@example.com"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "password123"
                    },
                    "password_confirmation": {
                        "type": "string",
                        "format": "password",
                        "example": "password123"
                    }
                },
                "type": "object"
            },
            "LoginRequest": {
                "required": [
                    "email",
                    "password"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "alice@example.com"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "password123"
                    }
                },
                "type": "object"
            },
            "StoreRucherRequest": {
                "required": [
                    "name",
                    "localisation",
                    "nb_emplacements"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Rucher des Tilleuls"
                    },
                    "localisation": {
                        "type": "string",
                        "example": "Lyon"
                    },
                    "description": {
                        "type": "string",
                        "example": "Rucher principal",
                        "nullable": true
                    },
                    "nb_emplacements": {
                        "type": "integer",
                        "example": 12,
                        "minimum": 0
                    }
                },
                "type": "object"
            },
            "UpdateRucherRequest": {
                "required": [
                    "name",
                    "localisation",
                    "nb_emplacements"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Rucher du Verger"
                    },
                    "localisation": {
                        "type": "string",
                        "example": "Grenoble"
                    },
                    "description": {
                        "type": "string",
                        "example": "Mise a jour du rucher",
                        "nullable": true
                    },
                    "nb_emplacements": {
                        "type": "integer",
                        "example": 16,
                        "minimum": 0
                    }
                },
                "type": "object"
            },
            "StoreRucheRequest": {
                "required": [
                    "rucher_id",
                    "nom",
                    "statut",
                    "type_ruche"
                ],
                "properties": {
                    "rucher_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "nom": {
                        "type": "string",
                        "example": "Ruche 01"
                    },
                    "statut": {
                        "type": "string",
                        "example": "active"
                    },
                    "type_ruche": {
                        "type": "string",
                        "example": "Dadant"
                    },
                    "annee_reine": {
                        "type": "integer",
                        "example": 2024,
                        "nullable": true
                    },
                    "notes": {
                        "type": "string",
                        "example": "Colonie tres dynamique",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "UpdateRucheRequest": {
                "properties": {
                    "rucher_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "nom": {
                        "type": "string",
                        "example": "Ruche 02"
                    },
                    "statut": {
                        "type": "string",
                        "example": "en observation"
                    },
                    "type_ruche": {
                        "type": "string",
                        "example": "Langstroth"
                    },
                    "annee_reine": {
                        "type": "integer",
                        "example": 2025,
                        "nullable": true
                    },
                    "notes": {
                        "type": "string",
                        "example": "Division recente",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "AuthResponse": {
                "required": [
                    "message",
                    "user",
                    "token"
                ],
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Connexion reussie"
                    },
                    "user": {
                        "$ref": "#/components/schemas/User"
                    },
                    "token": {
                        "type": "string",
                        "example": "1|aVeryLongSanctumToken"
                    }
                },
                "type": "object"
            },
            "RucherWriteResponse": {
                "required": [
                    "message",
                    "data"
                ],
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Rucher cree"
                    },
                    "data": {
                        "$ref": "#/components/schemas/Rucher"
                    }
                },
                "type": "object"
            },
            "RucheWriteResponse": {
                "required": [
                    "message",
                    "data"
                ],
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Ruche creee"
                    },
                    "data": {
