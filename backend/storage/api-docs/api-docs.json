{
    "openapi": "3.0.0",
    "info": {
        "title": "BeeKeeper API",
        "description": "Documentation OpenAPI des endpoints backend BeeKeeper.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Serveur courant"
        }
